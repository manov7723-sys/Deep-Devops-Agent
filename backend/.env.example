# ── Runtime ──────────────────────────────────────────────────────────────────
ENV=production
HOST=0.0.0.0
PORT=8000

# ── LLM ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=

# ── AWS (Terraform provisions infrastructure with these keys) ────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
YOUR_AWS_ACCOUNT_ID=

# ── GitHub (push Terraform / k8s manifests / CI workflows) ───────────────────
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=main

# ── Terraform remote state (S3) ──────────────────────────────────────────────
TF_STATE_BUCKET=
TF_STATE_REGION=us-east-1

# ── HashiCorp Vault (server-side credential storage) ─────────────────────────
VAULT_ADDR=http://127.0.0.1:8200
VAULT_TOKEN=

# ── MCP servers (auto-skipped when their variable is blank) ──────────────────
# Active set: GitHub, Terraform, Kubernetes, Prometheus, Grafana
ENABLE_TERRAFORM_MCP=false
PROMETHEUS_URL=
GRAFANA_URL=
GRAFANA_SERVICE_ACCOUNT_TOKEN=
