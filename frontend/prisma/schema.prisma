  owner
  developer
  viewer
}

enum HealthStatus {
  ok
  warn
  danger
}

enum CloudKind {
  aws
  gcp
  azure
  cloudflare
  digitalocean
}

enum ResourceCategory {
  compute
  network
  storage
  data
  cache
  security
  other
}

enum ProvisionedBy {
  terraform
  kubernetes
  manual
}

enum PipelineStatus {
  running
  succeeded
  failed
}

enum StageStatus {
  ok
  fail
  run
  wait
  skipped
}

enum DeploymentStatus {
  running
  succeeded
  failed
  rolled_back
}

enum ApprovalRisk {
  low
  medium
  high
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

enum DiffKind {
  add
  remove
  comment
}

enum AlertCategory {
  Security
  Performance
  Compliance
  Reliability
}

enum AlertSeverity {
  low
  medium
  high
}

enum AlertStatus {
  open
  ack
  resolved
}

enum KnowledgeType {
  Doc
  Runbook
}

enum IssueVerdict {
