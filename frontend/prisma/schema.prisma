// =============================================================================
// DeepAgent — corrected Prisma schema (redesign)
// -----------------------------------------------------------------------------
// Design rules applied (vs. the auto-generated schema.prisma):
//  1. No presentation strings as data. "2m ago", "$249/mo", "84.2k / day",
//     "Jun 28" become real DateTime / Int(cents) / Int columns. The UI does the
//     "2m ago" / "$x.xk" formatting at render time.
//  2. No duplicate Admin* tables. Admin dashboards are AGGREGATIONS/QUERIES over
//     the real User / Subscription / Invoice / Project tables. (see bottom note)
//  3. Real relations everywhere — FKs instead of loose strings (who, repo, env…).
//  4. Tenancy = PER-USER: a User owns Projects and has their own Subscription,
//     Usage, payment methods and invoices. Teammates are invited per-project.
//  5. Roles = enum owner | developer | viewer, carried on Membership.
//  6. Workloads + cloud resources unified into one ManagedResource model with
//     provisionedBy = terraform | kubernetes | manual, monitored when `enabled`.
//  7. Env rollback = immutable Deployment snapshots; Env points at its current one.
//
// Models marked  // ⚠ confirm   encode an assumption worth a sanity-check.
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  // pgvector support for knowledge-base embeddings (KnowledgeChunk.embedding).
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector] // requires `CREATE EXTENSION vector;` (pgvector)
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------
