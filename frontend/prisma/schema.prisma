// Mirrors Stripe subscription statuses verbatim (webhooks write these). Map to
// display labels in the UI (e.g. canceled/unpaid -> "Suspended", trialing -> "Trial").
enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
  unpaid
  incomplete
  incomplete_expired
  paused
}

enum AddonStatus {
  active
  cancelled
  pending
}

// Mirrors Stripe invoice statuses. UI maps void/uncollectible -> "Failed".
enum InvoiceStatus {
  draft
  open
  paid
  void
  uncollectible
}

enum ModelProvider {
  Anthropic
  OpenAI
  SelfHosted @map("Self-hosted")
  Google
  Groq
}

enum McpStatus {
  ok
  warn
  down
}

enum SecurityScopeKind {
  security_group
  iam_role
  kms_key
  secret_store
  network_policy
}

// ---------------------------------------------------------------------------
// Identity / profile / auth
// ---------------------------------------------------------------------------
enum OAuthProvider {
  github
  google
}

// Account-level role shown on the profile card. In per-user tenancy this
// reflects the account holder; project access is governed by Membership.role.
enum AccountRole {
  owner
  admin
  developer
  viewer
}

enum BillingPeriod {
  month
  year
  forever
  none
}

enum CardBrand {
  visa
  mastercard
  amex
  discover
  diners
  jcb
  unionpay
  unknown
}

enum TotpAlgorithm {
  SHA1
  SHA256
  SHA512
}

enum McpAuthType {
  none
  oauth
  credential
}

model User {
  id                    String      @id @default(uuid(7)) @db.Uuid
  email                 String      @unique
  name                  String
  firstName             String?
  lastName              String?
  avatarUrl             String?
  jobTitle              String?
  timezone              String?
  passwordHash          String?
  isSuperAdmin          Boolean     @default(false) // platform admin flag (NOT a project role)
  role                  AccountRole @default(owner) // account-level role (profile card)
  twoFactorEnabled      Boolean     @default(false)
  emailVerifiedAt       DateTime? // set when an email_verify MagicLink is consumed
  lastPasswordChangedAt DateTime? // "Password last changed …"
  termsAcceptedAt       DateTime? // signup "I agree to Terms"
  stripeCustomerId      String?     @unique // Stripe Customer (cus_…); anchor for all billing
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  // "project count" the UI wants = ownedProjects.length (derived, never stored stale)
  ownedProjects         Project[]
  memberships           Membership[]
  membershipsAdded      Membership[]        @relation("MembershipInvitedBy")
  invitationsSent       ProjectInvitation[] @relation("InvitationsSent")
  invitationsAccepted   ProjectInvitation[] @relation("InvitationsAccepted")
  // "current subscription details" = this relation
  subscription          Subscription?
  // "current token usage" = usage counters + weekly samples
  usage                 Usage?
  usageSamples          UsageSample[]
  notifications         Notification[]
  backupCodes           BackupCode[]
  sessions              Session[]
  magicLinks            MagicLink[]
  paymentMethods        PaymentMethod[]
  invoices              Invoice[]
  repos                 Repo[]
  cloudProviders        CloudProvider[]
  chatMessages          ChatMessage[]
  activities            Activity[]
  approvalsDecided      Approval[]
  pipelinesRun          Pipeline[]
  deployments           Deployment[]
  knowledgeDocs         KnowledgeDoc[]
  integrationsConnected Integration[]
  checkoutSessions      CheckoutSession[]
  oauthAccounts         OAuthAccount[]
  totp                  TotpCredential?
  auditLogs             AuditLog[]
}

enum NotifKind {
  approval
  deployment
  alert
  billing
  member
  system
}

model Notification {
  id        String     @id @default(uuid(7)) @db.Uuid
  userId    String     @db.Uuid
  category  NotifKind? // semantic kind; `icon` is the glyph the UI maps to
  icon      String
  title     String
  subtitle  String
  read      Boolean    @default(false)
  readAt    DateTime?
  linkHref  String? // deep-link target when the notification is clicked
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model BackupCode {
  id        String    @id @default(uuid(7)) @db.Uuid
  userId    String    @db.Uuid
  batchId   String? // groups a regenerated set; "Regenerate" replaces the batch
  codeHash  String // never store the plaintext code
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, codeHash])
  @@index([userId, batchId])
}

// Server-side session (replaces the stateless ddasess/ddatemp cookie payloads).
// The cookie carries only `tokenHash`'s opaque token; the row holds the state.
// Flow: password verified -> pending_mfa (short TTL) -> TOTP ok -> active (7d).
enum SessionStatus {
  pending_mfa // ddatemp stage: awaiting TOTP
  active // ddasess stage: fully authenticated
  revoked
  expired
}

model Session {
  id              String        @id @default(uuid(7)) @db.Uuid
  userId          String        @db.Uuid
  tokenHash       String        @unique // hash of the cookie token, never the raw token
  status          SessionStatus @default(pending_mfa)
  forcedTotpSetup Boolean       @default(false) // signup -> must set up TOTP
  rememberMe      Boolean       @default(false) // "Remember me" -> longer TTL
  mfaSatisfiedAt  DateTime? // when pending_mfa -> active (TOTP passed)
  deviceLabel     String? // human label for the "Review devices" list
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime      @default(now())
  lastSeenAt      DateTime      @default(now())
  expiresAt       DateTime
  revokedAt       DateTime? // set on logout / "sign out other sessions"

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
  @@index([expiresAt])
}

// Single-use emailed token: passwordless login, password reset, email verify,
// or invite. The email carries an opaque token; the DB stores only its hash.
enum MagicLinkPurpose {
  login
  password_reset
  email_verify
  invite
}

model MagicLink {
  id          String           @id @default(uuid(7)) @db.Uuid
  userId      String?          @db.Uuid // null when the email isn't a known account yet (invite/signup)
  email       String // target email (always recorded)
  tokenHash   String           @unique
  purpose     MagicLinkPurpose
  expiresAt   DateTime
  consumedAt  DateTime? // set when redeemed; enforces single use
  requestedIp String?
  createdAt   DateTime         @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([expiresAt])
}

// OAuth sign-in identity ("Continue with GitHub/Google"). Links a provider
// account to a User; tokens stored as encrypted refs, never plaintext.
model OAuthAccount {
  id                String        @id @default(uuid(7)) @db.Uuid
  userId            String        @db.Uuid
  provider          OAuthProvider
  providerAccountId String // the user id at GitHub/Google
  /**
   * Denormalized handle from the provider (GitHub `login` or Google email
   * local-part). Used to render multi-account UIs without re-hitting the
   * provider's /user endpoint. Nullable for rows created before this column
   * was added; backfilled on next token refresh.
   */
  login             String?
  avatarUrl         String?
  accessTokenRef    String? // encrypted ref / secret-manager handle
  refreshTokenRef   String?
  tokenExpiresAt    DateTime?
  scope             String?
  createdAt         DateTime      @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  repos Repo[]

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// TOTP enrollment (1-to-1 with User). Distinguishes pending (secret created
// during forced setup) from confirmed (first valid code seen). Replaces the
// bare User.totpSecret string.
model TotpCredential {
  id          String        @id @default(uuid(7)) @db.Uuid
  userId      String        @unique @db.Uuid
  secretRef   String // encrypted ref / secret-manager handle (never plaintext)
  label       String? // "Google Authenticator"
  algorithm   TotpAlgorithm @default(SHA1)
  digits      Int           @default(6)
  period      Int           @default(30)
  confirmedAt DateTime? // null until first valid code (pending vs confirmed)
  enrolledAt  DateTime      @default(now())
  disabledAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Billing — per-user subscription, plans, addons, invoices, usage
// ---------------------------------------------------------------------------
model Plan {
  id              String        @id @default(uuid(7)) @db.Uuid
  tier            PlanTier      @unique
  name            String
  // priceCents null + isCustomPrice = "Custom" (Enterprise).
  priceCents      Int?
  isCustomPrice   Boolean       @default(false)
  currency        String        @default("usd")
  period          BillingPeriod @default(month)
  popular         Boolean       @default(false)
  sortOrder       Int           @default(0) // catalog ordering
  // Stripe catalog mapping. Enterprise/Custom plans may have null prices.
  stripeProductId String? // prod_…
  stripePriceId   String? // price_… (monthly); add a yearly id if you offer annual
  // Entitlements: null = unlimited.
  projectLimit    Int?
  envLimit        Int?
  seatLimit       Int?
  agentTier       String? // "Community agents", "All agents + custom models", …
  highlights      String[]

  subscriptions Subscription[]
}

model Subscription {
  id                   String             @id @default(uuid(7)) @db.Uuid
  userId               String             @unique @db.Uuid // one active subscription per user
  planId               String             @db.Uuid
  status               SubscriptionStatus @default(incomplete)
  basePriceCents       Int
  currency             String             @default("usd")
  // Stripe references — Stripe is the source of truth; these are synced via webhook.
  stripeSubscriptionId String?            @unique // sub_…
  stripePriceId        String? // active price_…
  cancelAtPeriodEnd    Boolean            @default(false)
  // currentPeriodEnd = the "Renews on" date; renewsLabel holds non-date dunning
  // text for past_due/suspended rows ("Overdue 3d", "—") that has no date.
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  renewsLabel          String?
  trialEndsAt          DateTime?
  canceledAt           DateTime?
  // Cached default card for display only (synced from Stripe); see PaymentMethod.
  paymentMethodId      String?            @db.Uuid
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan          Plan                @relation(fields: [planId], references: [id])
  paymentMethod PaymentMethod?      @relation(fields: [paymentMethodId], references: [id])
  addons        SubscriptionAddon[]
  invoices      Invoice[]
}

// Read-model CACHE of a Stripe payment method, for display only. The app never
// collects card data — cards are added/edited in Stripe's hosted Customer Portal,
// and these rows are kept in sync via webhooks. Stripe charges the customer; we
// don't store a chargeable token.
model PaymentMethod {
  id                    String    @id @default(uuid(7)) @db.Uuid
  userId                String    @db.Uuid
  stripePaymentMethodId String    @unique // pm_…
  brand                 CardBrand // normalized from Stripe's brand string
  last4                 String
  expMonth              Int
  expYear               Int
  // One default per user — enforce with a partial-unique index in a raw SQL
  // migration: CREATE UNIQUE INDEX ... ON "PaymentMethod"("userId") WHERE "isDefault".
  isDefault             Boolean   @default(false)
  createdAt             DateTime  @default(now())

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]

  @@index([userId])
}

// Catalog of purchasable add-ons. Add-ons are ONE-TIME purchases (mode=payment
// in Stripe Checkout). `tokenGrant` records how many agent tokens the purchase
// adds to the buyer's Usage.tokensGranted balance.
model Addon {
  id              String   @id @default(uuid(7)) @db.Uuid
  name            String
  icon            String
  description     String
  priceCents      Int
  currency        String   @default("usd")
  tokenGrant      Int      @default(0) // additional agent tokens added per purchase
  active          Boolean  @default(true) // hide retired add-ons without deleting
  stripeProductId String? // prod_…
  stripePriceId   String? // price_… (must be a ONE-TIME price in Stripe)
  createdAt       DateTime @default(now())

  purchases SubscriptionAddon[]
}

// A purchased add-on (a Stripe subscription item on the user's subscription).
// Admin "addon purchases" view = query over this + user.
model SubscriptionAddon {
  id                       String      @id @default(uuid(7)) @db.Uuid
  subscriptionId           String      @db.Uuid
  addonId                  String?     @db.Uuid
  name                     String // snapshot of the name at purchase time
  icon                     String
  priceCents               Int // purchase-time price snapshot
  status                   AddonStatus @default(active)
  stripeSubscriptionItemId String?     @unique // si_…
  purchasedAt              DateTime    @default(now())
  cancelledAt              DateTime?

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  addon        Addon?       @relation(fields: [addonId], references: [id])

  @@index([subscriptionId])
}

// Mirror of a Stripe invoice (source of truth = Stripe; synced via webhook).
model Invoice {
  id               String        @id @default(uuid(7)) @db.Uuid
  stripeInvoiceId  String?       @unique // in_…
  number           String?       @unique // Stripe invoice number; null until finalized
  userId           String        @db.Uuid
  subscriptionId   String?       @db.Uuid
  customerName     String? // billing-entity label snapshot ("Northwind Commerce")
  amountCents      Int
  currency         String        @default("usd")
  status           InvoiceStatus
  hostedInvoiceUrl String? // Stripe-hosted invoice page
  pdfUrl           String? // invoice_pdf
  issuedAt         DateTime
  paidAt           DateTime?
  createdAt        DateTime      @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  @@index([userId, status])
  @@index([userId, issuedAt])
}

// Current-period usage counters. Limits derive from the plan but are cached
// here so per-user overrides (add-ons) are representable.
model Usage {
  id             String   @id @default(uuid(7)) @db.Uuid
  userId         String   @unique @db.Uuid
  periodStart    DateTime
  periodEnd      DateTime
  agentRunsUsed  Int      @default(0)
  agentRunsLimit Int? // null = unlimited
  deploysUsed    Int      @default(0)
  deploysLimit   Int?
  seatsUsed      Int      @default(0)
  seatsLimit     Int?
  envsUsed       Int      @default(0)
  envsLimit      Int?
  // Tokens are tracked separately from the run-count counters. `tokensGranted`
  // grows when a Token Boost addon is purchased; `tokensUsed` grows as agents
  // run. Remaining balance = tokensGranted + plan baseline - tokensUsed.
  tokensUsed     BigInt   @default(0)
  tokensGranted  BigInt   @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Weekly token series for the usage sparkline (replaces the `tokens: Int[]` blob).
model UsageSample {
  id        String   @id @default(uuid(7)) @db.Uuid
  userId    String   @db.Uuid
  weekStart DateTime
  tokens    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Stripe plumbing (redirect to Checkout / Customer Portal)
// ---------------------------------------------------------------------------
// Webhook idempotency + audit. On each webhook: insert by Stripe event id BEFORE
// processing and skip if it already exists -> exactly-once handling.
model StripeEvent {
  id          String    @id // Stripe event id (evt_…)
  type        String // "invoice.paid", "customer.subscription.updated", …
  apiVersion  String?
  payload     Json?
  receivedAt  DateTime  @default(now())
  processedAt DateTime?
  error       String?

  @@index([type])
}

enum CheckoutMode {
  subscription
  setup
  payment
}

enum CheckoutStatus {
  open
  complete
  expired
}

// Correlates a redirect to Stripe Checkout with the initiating user + intent, so
// the success/cancel return and the async webhook reconcile to one record.
model CheckoutSession {
  id          String         @id // Stripe Checkout Session id (cs_…)
  userId      String         @db.Uuid
  mode        CheckoutMode
  status      CheckoutStatus @default(open)
  purpose     String? // "new_subscription" | "add_addon" | "update_payment_method"
  createdAt   DateTime       @default(now())
  completedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Projects + membership
// ---------------------------------------------------------------------------
model Project {
  id          String       @id @default(uuid(7)) @db.Uuid
  slug        String       @unique
  ownerId     String       @db.Uuid
  name        String
  colorHue    Int
  description String
  health      HealthStatus @default(ok)
  cloud       String? // the cloud this project targets: "aws" | "gcp" | "azure" (locks the Connect-provider UI)
  archivedAt  DateTime? // "Archive project" (reversible) — read-only, agents paused
  deletedAt   DateTime? // soft-delete; retained for undo/audit before hard purge
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  owner             User                   @relation(fields: [ownerId], references: [id])
  memberships       Membership[]
  invitations       ProjectInvitation[]
  // `envs`, `repos` (counts) and `cloud[]` are DERIVED from these relations:
  environments      Env[]
  projectRepos      ProjectRepo[]
  pipelines         Pipeline[]
  ciPipelines       CiPipeline[]
  cloudProviders    CloudProvider[]
  vaultConfig       VaultConfig?
  approvals         Approval[]
  activities        Activity[]
  alerts            Alert[]
  knowledgeDocs     KnowledgeDoc[]
  issues            Issue[]
  chatThreads       ChatThread[]
  chatMessages      ChatMessage[]
  chatSuggestions   ChatSuggestion[]
  tasks             Task[]
  resources         ManagedResource[]
  integrations      Integration[]
  mcpConnections    ProjectMcpConnection[]
  observabilityKpis ObservabilityKpi[]
  prometheusTargets PrometheusTarget[]
  grafanaDashboards GrafanaDashboard[]
  auditLogs         AuditLog[]
  settings          ProjectSetting?
  costSnapshots     CostSnapshot[]
  costTrend         CostTrendPoint[]

  @@index([ownerId])
}

// An ACCEPTED member of a project (real User). Pending email invites live in
// ProjectInvitation, not here. lastActive is derived from Activity, not stored.
// The u/teams "projects" count per person = that user's Membership count.
model Membership {
  id          String      @id @default(uuid(7)) @db.Uuid
  projectId   String      @db.Uuid
  userId      String      @db.Uuid
  role        ProjectRole @default(viewer)
  invitedById String?     @db.Uuid // who added them (provenance)
  joinedAt    DateTime    @default(now())

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitedBy User?   @relation("MembershipInvitedBy", fields: [invitedById], references: [id])

  @@unique([projectId, userId])
  @@index([userId])
}

// Pending email invite to a project — exists BEFORE the invitee has a Membership
// (and possibly before they have a User account at all). Resend = new MagicLink;
// accept = create Membership + mark accepted. Backs the InviteMemberModal flow.
enum InvitationStatus {
  pending
  accepted
  revoked
  expired
}

model ProjectInvitation {
  id             String           @id @default(uuid(7)) @db.Uuid
  projectId      String           @db.Uuid
  email          String // invitee — may not be a User yet
  role           ProjectRole      @default(viewer)
  status         InvitationStatus @default(pending)
  invitedById    String           @db.Uuid
  acceptedUserId String?          @db.Uuid // the User who accepted (set on accept)
  magicLinkId    String? // the emailed invite token (MagicLink.purpose = invite)
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime         @default(now())

  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  invitedBy    User    @relation("InvitationsSent", fields: [invitedById], references: [id])
  acceptedUser User?   @relation("InvitationsAccepted", fields: [acceptedUserId], references: [id])

  @@unique([projectId, email]) // one live invite per email per project
  @@index([email])
}

model ProjectSetting {
  id                     String  @id @default(uuid(7)) @db.Uuid
  projectId              String  @unique @db.Uuid
  defaultBranch          String  @default("main")
  autoDeployNonProd      Boolean @default(true)
  requireApprovalRelease Boolean @default(true)
  defaultModelId         String? @db.Uuid

  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  defaultModel Model?  @relation(fields: [defaultModelId], references: [id])
}

// ---------------------------------------------------------------------------
// Repos — account-level (a connected GitHub repo), wired into projects & envs
// ---------------------------------------------------------------------------
model Repo {
  id              String         @id @default(uuid(7)) @db.Uuid
  ownerId         String         @db.Uuid // the user whose GitHub connection owns this repo
  /**
   * The specific OAuth identity row this repo was discovered through. A user
   * may have multiple connected GitHub accounts; this binds the repo to the
   * one whose token grants access. Nullable for rows created before this
   * column was added; backfilled lazily on next sync.
   */
  oauthAccountId  String?        @db.Uuid
  fullName        String // e.g. "alice/api"
  name            String
  description     String?
  lang            String // TypeScript | HCL | YAML | Python | …
  kind            RepoKind
  defaultBranch   String         @default("main")
  visibility      RepoVisibility @default(private)
  openIssues      Int            @default(0)
  openPrs         Int            @default(0)
  lastCommitSha   String?
  lastCommitAt    DateTime?
  deletedAt       DateTime? // soft-delete on disconnect; retained for undo/audit
  createdAt       DateTime       @default(now())

  owner           User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  oauthAccount    OAuthAccount?    @relation(fields: [oauthAccountId], references: [id], onDelete: SetNull)
  projectRepos    ProjectRepo[]
  envRepos        EnvRepo[]
  pipelines       Pipeline[]
  ciPipelines     CiPipeline[]
  issues          Issue[]
  knowledgeDocs   KnowledgeDoc[]
  deploymentRepos DeploymentRepo[]
  approvals       Approval[]
  chatPrRefs      ChatMessage[]    @relation("ChatPrRepo")
  chatPlanSteps   ChatPlanStep[]

  // The (oauthAccount, fullName) pair is the strong identity (matches reality:
  // the same `alice/api` repo can exist under two different connected
  // identities). (ownerId, fullName) is kept as a soft fallback for legacy
  // rows where oauthAccountId is null.
  @@unique([oauthAccountId, fullName])
  @@unique([ownerId, fullName])
  @@index([ownerId])
  @@index([oauthAccountId])
}

// Repo ↔ Project association ("which repos belong to this project").
model ProjectRepo {
  id        String   @id @default(uuid(7)) @db.Uuid
  projectId String   @db.Uuid
  repoId    String   @db.Uuid
  addedAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  repo    Repo    @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@unique([projectId, repoId])
}

// Repo wired into a specific environment, tracking a branch. This is the
// "map repo within the env" / "repo is part of envs" relationship.
model EnvRepo {
  id         String   @id @default(uuid(7)) @db.Uuid
  envId      String   @db.Uuid
  repoId     String   @db.Uuid
  branch     String
  autoDeploy Boolean  @default(false)
  createdAt  DateTime @default(now())

  env  Env  @relation(fields: [envId], references: [id], onDelete: Cascade)
  repo Repo @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@unique([envId, repoId])
}

// ---------------------------------------------------------------------------
// Environments — each env picks a cloud provider, maps repos, keeps deploy history
// ---------------------------------------------------------------------------
model Env {
  id                  String   @id @default(uuid(7)) @db.Uuid
  projectId           String   @db.Uuid
  cloudProviderId     String?  @db.Uuid // the cloud this env is deployed to (chosen at create)
  key                 String // "alpha" | "beta" | "release" | custom (no longer a fixed enum)
  name                String
  url                 String?
  isProduction        Boolean  @default(false)
  autoDeploy          Boolean  @default(false)
  region              String? // default cloud region for this env
  terraformWorkspace  String? // IaC workspace backing this env
  /**
   * Encrypted kubeconfig YAML the executor writes to disk before running
   * helm/kubectl. Null means "no cluster wired yet" — pipelines that need
   * Kubernetes will fail-fast with `env_missing_kubeconfig`.
   */
  kubeconfigRef       String?
  /** Namespace to deploy app workloads into. Created if absent. */
  namespace           String   @default("default")
  /**
   * Terraform remote-state backend bootstrap. On first Terraform use we
   * provision a per-project S3 bucket + DynamoDB lock table; the values are
   * recorded here so subsequent runs reference the same backend in their
   * HCL. Null means "Terraform not yet initialized for this env".
   */
  tfBackendBucket     String?
  tfBackendRegion     String?
  tfBackendTable      String?
  promotionRank       Int      @default(0) // ordering: alpha(0) -> beta(1) -> release(2)
  currentDeploymentId String?  @unique @db.Uuid // active deployment; re-point to roll back
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  project           Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  cloudProvider     CloudProvider?       @relation(fields: [cloudProviderId], references: [id])
  currentDeployment Deployment?          @relation("EnvCurrentDeployment", fields: [currentDeploymentId], references: [id])
  deployments       Deployment[]         @relation("EnvDeployments")
  envRepos          EnvRepo[]
  resources         ManagedResource[]
  pipelines         Pipeline[]
  approvals         Approval[]
  alerts            Alert[]
  activities        Activity[]
  knowledgeDocs     KnowledgeDoc[]
  tasks             Task[]
  securityBindings  EnvSecurityBinding[]
  costByEnv         CostByEnv[]

  @@unique([projectId, key])
  @@index([projectId])
}

// Immutable deployment snapshot — the unit of rollback. Each deploy records the
// exact repo SHAs that went out; rollback = set Env.currentDeploymentId to a
// prior row (recorded as a new rolled_back Deployment if you want an audit trail).
model Deployment {
  id                 String           @id @default(uuid(7)) @db.Uuid
  envId              String           @db.Uuid
  sequence           Int // monotonically increasing per env (#1, #2, …)
  status             DeploymentStatus @default(running)
  triggeredById      String?          @db.Uuid // user, if human-triggered
  triggeredByAgentId String?          @db.Uuid
  rollbackOfId       String?          @db.Uuid // set when this deploy reverts to an earlier one
  // Infra state captured at deploy time — lets rollback revert INFRASTRUCTURE,
  // not just code SHAs. Re-applying these restores the env exactly.
  tfStateRef         String? // pointer to the Terraform state/version for this deploy
  tfPlanRef          String? // pointer to the applied terraform plan artifact
  infraSnapshot      Json? // resolved config (image tags, replicas, env-var refs)
  note               String?
  createdAt          DateTime         @default(now())
  finishedAt         DateTime?

  env              Env              @relation("EnvDeployments", fields: [envId], references: [id], onDelete: Cascade)
  currentOfEnv     Env?             @relation("EnvCurrentDeployment")
  triggeredBy      User?            @relation(fields: [triggeredById], references: [id])
  triggeredByAgent Agent?           @relation(fields: [triggeredByAgentId], references: [id])
  rollbackOf       Deployment?      @relation("DeploymentRollback", fields: [rollbackOfId], references: [id])
  rollbacks        Deployment[]     @relation("DeploymentRollback")
  repos            DeploymentRepo[]
  pipeline         Pipeline?

  @@unique([envId, sequence])
  @@index([envId])
}

// Per-repo SHA captured in a deployment (what code was live).
model DeploymentRepo {
  id           String   @id @default(uuid(7)) @db.Uuid
  deploymentId String   @db.Uuid
  repoId       String   @db.Uuid
  sha          String
  branch       String
  createdAt    DateTime @default(now())

  deployment Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
  repo       Repo       @relation(fields: [repoId], references: [id])

  @@unique([deploymentId, repoId])
}

// ---------------------------------------------------------------------------
// Managed resources — unified workloads + cloud resources (k8s & terraform)
// ---------------------------------------------------------------------------
model ManagedResource {
  id              String           @id @default(uuid(7)) @db.Uuid
  projectId       String           @db.Uuid
  envId           String           @db.Uuid
  cloudProviderId String?          @db.Uuid
  name            String
  category        ResourceCategory
  type            String // "EKS · 6 nodes", "RDS Postgres · db.r6g.xlarge", …
  provisionedBy   ProvisionedBy    @default(terraform)
  enabled         Boolean          @default(true) // monitored when enabled
  region          String?
  status          HealthStatus     @default(ok)
  // Optional metrics — populated per resource kind.
  cpuPct          Int?
  memPct          Int?
  replicasReady   Int?
  replicasDesired Int?
  // Free-form extras the UI shows: badges[], policy hint, k8s requests/limits…
  attributes      Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  env           Env            @relation(fields: [envId], references: [id], onDelete: Cascade)
  cloudProvider CloudProvider? @relation(fields: [cloudProviderId], references: [id])

  @@index([projectId, envId])
  @@index([envId, category])
  @@index([category])
}

// ---------------------------------------------------------------------------
// CI/CD — pipelines + stages
// ---------------------------------------------------------------------------
model Pipeline {
  id                 String         @id @default(uuid(7)) @db.Uuid
  projectId          String         @db.Uuid
  envId              String         @db.Uuid
  repoId             String         @db.Uuid // repo is part of the env (see EnvRepo)
  branch             String
  sha                String
  status             PipelineStatus @default(running)
  triggeredById      String?        @db.Uuid
  triggeredByAgentId String?        @db.Uuid
  startedAt          DateTime       @default(now())
  finishedAt         DateTime?
  durationSec        Int?
  progressPct        Int            @default(0)
  attempt            Int            @default(1) // retry counter
  retryOfId          String?        @db.Uuid // the original run this is a retry of
  deploymentId       String?        @unique @db.Uuid // the deployment this run produced, if any

  project          Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  env              Env             @relation(fields: [envId], references: [id])
  repo             Repo            @relation(fields: [repoId], references: [id])
  triggeredBy      User?           @relation(fields: [triggeredById], references: [id])
  triggeredByAgent Agent?          @relation(fields: [triggeredByAgentId], references: [id])
  deployment       Deployment?     @relation(fields: [deploymentId], references: [id])
  retryOf          Pipeline?       @relation("PipelineRetry", fields: [retryOfId], references: [id])
  retries          Pipeline[]      @relation("PipelineRetry")
  stages           PipelineStage[]

  @@index([projectId, envId])
}

/// A CI/CD pipeline the agent generated in chat and the user SAVED to the
/// project (not yet on GitHub). Its `files` (Dockerfile, workflow YAML, …) are
/// editable in the CI/CD UI. "Run pipeline" commits them to the repo's default
/// branch and triggers the GitHub Actions workflow; the app mirrors the run's
/// live status. When `agentReview` is on, a failed run is auto-reviewed, fixed,
/// and re-run by the agent (bounded by `healAttempts`).
model CiPipeline {
  id           String   @id @default(uuid(7)) @db.Uuid
  projectId    String   @db.Uuid
  repoId       String   @db.Uuid
  name         String
  files        Json // [{ path, content }] — editable
  workflowPath String? // path of the workflow file within `files`
  branch       String   @default("main")
  status       String   @default("draft") // draft | committing | running | success | failed | error
  agentReview  Boolean  @default(false) // auto-heal failed runs with the agent
  healAttempts Int      @default(0) // bounds the auto-heal loop
  commitSha    String?
  runId        String? // GitHub Actions run id
  runUrl       String? // html_url of the run
  conclusion   String? // GitHub run conclusion (success|failure|…)
  stages       Json? // cached [{ name, status, conclusion, errorLog? }] for the UI
  lastError    String? // short error summary surfaced in the UI
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  repo    Repo    @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model PipelineStage {
  id         String      @id @default(uuid(7)) @db.Uuid
  pipelineId String      @db.Uuid
  label      String // human-readable name e.g. "Clone repos" or "Terraform plan"
  status     StageStatus
  order      Int
  createdAt  DateTime    @default(now())
  /**
   * Execution tracking — populated by the runner when the stage actually
   * runs against a cluster / cloud. Nullable so existing rows (display-only
   * stages from before Phase 1) still validate.
   */
  startedAt  DateTime?
  finishedAt DateTime?
  /** Last ~32KB of stdout/stderr from the runner. Newer log lines win when
   *  the buffer fills. For long runs, move to S3 in a later phase. */
  logs       String      @default("")
  exitCode   Int?

  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@index([pipelineId, order])
}

// ---------------------------------------------------------------------------
// Approvals
// ---------------------------------------------------------------------------
model Approval {
  id                 String         @id @default(uuid(7)) @db.Uuid
  projectId          String         @db.Uuid
  envId              String         @db.Uuid
  title              String
  summary            String?
  requestedByAgentId String?        @db.Uuid
  repoId             String?        @db.Uuid
  changesSummary     String? // "+3 resources", "1 file changed"
  risk               ApprovalRisk
  status             ApprovalStatus @default(pending)
  requestedAt        DateTime       @default(now())
  decidedAt          DateTime?
  decidedById        String?        @db.Uuid

  project          Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  env              Env            @relation(fields: [envId], references: [id])
  requestedByAgent Agent?         @relation(fields: [requestedByAgentId], references: [id])
  repo             Repo?          @relation(fields: [repoId], references: [id])
  decidedBy        User?          @relation(fields: [decidedById], references: [id])
  diff             ApprovalDiff[]

  @@index([projectId, status])
}

model ApprovalDiff {
  id         String   @id @default(uuid(7)) @db.Uuid
  approvalId String   @db.Uuid
  kind       DiffKind
  text       String
  order      Int

  approval Approval @relation(fields: [approvalId], references: [id], onDelete: Cascade)

  @@index([approvalId])
}

// ---------------------------------------------------------------------------
// Activity feed
// ---------------------------------------------------------------------------
model Activity {
  id           String   @id @default(uuid(7)) @db.Uuid
  projectId    String   @db.Uuid
  // Actor is a user OR an agent. actorLabel is a display fallback.
  actorUserId  String?  @db.Uuid
  actorAgentId String?  @db.Uuid
  actorLabel   String?
  action       String // "shipped", "approved", "flagged", …
  targetLabel  String // "northwind-api@9af20bc"
  targetType   String?
  envId        String?  @db.Uuid // null = shared / cross-env
  icon         String?
  createdAt    DateTime @default(now())

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  actorUser  User?   @relation(fields: [actorUserId], references: [id])
  actorAgent Agent?  @relation(fields: [actorAgentId], references: [id])
  env        Env?    @relation(fields: [envId], references: [id])

  @@index([projectId, createdAt])
}

// ---------------------------------------------------------------------------
// Alerts
// ---------------------------------------------------------------------------
model Alert {
  id             String        @id @default(uuid(7)) @db.Uuid
  projectId      String        @db.Uuid
  envId          String        @db.Uuid
  title          String
  detail         String
  resource       String
  sourceAgentId  String?       @db.Uuid
  sourceLabel    String? // fallback when the source isn't a known Agent
  category       AlertCategory
  severity       AlertSeverity
  recommendation String
  status         AlertStatus   @default(open)
  detectedAt     DateTime      @default(now())
  resolvedAt     DateTime?
  // SRE agent auto-triage: the diagnosis JSON (summary/rootCause/evidence/
  // remediation/confidence) the agent produced when this alert fired, so the UI
  // can show it without the user clicking. Null = not yet investigated.
  aiDiagnosis    Json?
  aiDiagnosedAt  DateTime?

  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  env         Env     @relation(fields: [envId], references: [id])
  sourceAgent Agent?  @relation(fields: [sourceAgentId], references: [id])

  @@index([projectId, category])
  @@index([projectId, status])
}

// ---------------------------------------------------------------------------
// Knowledge base
// ---------------------------------------------------------------------------
// A doc is either authored text (`source = written`) OR an uploaded file
// (`source = upload`, e.g. PDF/DOCX) that gets ingested into KnowledgeChunk
// rows for embedding-based retrieval.
enum KnowledgeSource {
  written
  upload
}

enum KnowledgeIngestStatus {
  pending // queued for chunking/embedding
  processing
  ready
  failed
}

model KnowledgeDoc {
  id            String                @id @default(uuid(7)) @db.Uuid
  projectId     String                @db.Uuid
  repoId        String?               @db.Uuid
  envId         String?               @db.Uuid // null = shared
  authorUserId  String?               @db.Uuid
  title         String
  excerpt       String
  body          String? // present for written docs
  type          KnowledgeType
  tags          String[]
  // Upload metadata — set when source = upload.
  source        KnowledgeSource       @default(written)
  fileName      String?
  mimeType      String? // "application/pdf", …
  fileSizeBytes Int?
  storageRef    String? // S3/GCS object key for the uploaded file
  pageCount     Int?
  ingestStatus  KnowledgeIngestStatus @default(ready)
  ingestError   String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  project Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  repo    Repo?            @relation(fields: [repoId], references: [id])
  env     Env?             @relation(fields: [envId], references: [id])
  author  User?            @relation(fields: [authorUserId], references: [id])
  chunks  KnowledgeChunk[]

  @@index([projectId])
}

// A retrievable chunk of a knowledge doc (split from body or an uploaded file),
// with its embedding for vector similarity search.
model KnowledgeChunk {
  id         String                       @id @default(uuid(7)) @db.Uuid
  docId      String                       @db.Uuid
  chunkIndex Int // ordinal within the doc
  content    String
  tokenCount Int?
  page       Int? // source page for PDFs
  // Dimension MUST match the embedding model (1536 = OpenAI text-embedding-3-small;
  // adjust for the model you use). Build an HNSW/IVFFlat index via raw SQL migration.
  embedding  Unsupported("vector(1536)")?
  createdAt  DateTime                     @default(now())

  doc KnowledgeDoc @relation(fields: [docId], references: [id], onDelete: Cascade)

  @@unique([docId, chunkIndex])
  @@index([docId])
}

// ---------------------------------------------------------------------------
// Issues (agent code review on project repos)
// ---------------------------------------------------------------------------
model Issue {
  id                String        @id @default(uuid(7)) @db.Uuid
  number            Int
  projectId         String        @db.Uuid
  repoId            String        @db.Uuid
  title             String
  note              String
  labels            String[]
  reviewedByAgentId String?       @db.Uuid
  verdict           IssueVerdict? // set when an agent review completes
  state             IssueState    @default(open)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  project         Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  repo            Repo    @relation(fields: [repoId], references: [id])
  reviewedByAgent Agent?  @relation(fields: [reviewedByAgentId], references: [id])

  @@unique([repoId, number])
  @@index([projectId, state])
  @@index([reviewedByAgentId, verdict])
}

// ---------------------------------------------------------------------------
// Chat (agent conversation, per project)
// ---------------------------------------------------------------------------
model ChatThread {
  id        String   @id @default(uuid(7)) @db.Uuid
  projectId String   @db.Uuid
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project  Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([projectId])
}

model ChatMessage {
  id           String   @id @default(uuid(7)) @db.Uuid
  projectId    String   @db.Uuid
  threadId     String?  @db.Uuid // groups messages into a conversation
  role         ChatRole
  authorUserId String?  @db.Uuid // set when role = user
  agentId      String?  @db.Uuid // set when role = agent — which agent replied
  modelId      String?  @db.Uuid // model that generated the agent reply (optional)
  text         String
  codeBody     String?
  codeLang     String?
  prNumber     Int?
  prRepoId     String?  @db.Uuid
  createdAt    DateTime @default(now())

  project   Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  thread    ChatThread?    @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author    User?          @relation(fields: [authorUserId], references: [id])
  agent     Agent?         @relation(fields: [agentId], references: [id])
  model     Model?         @relation(fields: [modelId], references: [id])
  prRepo    Repo?          @relation("ChatPrRepo", fields: [prRepoId], references: [id])
  planSteps ChatPlanStep[]

  @@index([projectId, createdAt])
  @@index([threadId])
}

model ChatPlanStep {
  id        String  @id @default(uuid(7)) @db.Uuid
  messageId String  @db.Uuid
  icon      String
  label     String
  repoId    String? @db.Uuid
  order     Int

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  repo    Repo?       @relation(fields: [repoId], references: [id])

  @@index([messageId])
}

model ChatSuggestion {
  id        String   @id @default(uuid(7)) @db.Uuid
  projectId String?  @db.Uuid // null = global default suggestion
  icon      String
  text      String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Scheduled agent tasks
// ---------------------------------------------------------------------------
model Task {
  id              String     @id @default(uuid(7)) @db.Uuid
  projectId       String     @db.Uuid
  agentId         String?    @db.Uuid
  envId           String?    @db.Uuid // null + allEnvs=true => runs across all envs
  allEnvs         Boolean    @default(false)
  title           String
  icon            String
  schedule        String // cron or human cadence; consider a typed cron later
  lastRunAt       DateTime?
  nextRunAt       DateTime?
  status          TaskStatus @default(ok)
  findingsSummary String?
  progressPct     Int?
  createdAt       DateTime   @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  agent   Agent?  @relation(fields: [agentId], references: [id])
  env     Env?    @relation(fields: [envId], references: [id])

  @@index([projectId])
  @@index([nextRunAt])
}

// ---------------------------------------------------------------------------
// Cloud providers + security scopes
// ---------------------------------------------------------------------------
model CloudProvider {
  id         String       @id @default(uuid(7)) @db.Uuid
  userId     String       @db.Uuid // who connected it
  projectId  String?      @db.Uuid // ISOLATION: a provider belongs to ONE project. The same cloud account reused in another project is a separate row.
  kind       CloudKind
  name       String
  accountRef String // "northwind-prod · 461298145672"
  accountId  String?
  roleArn    String? // scoped IAM role the agent assumes (no long-lived keys)
  externalId String? // STS AssumeRole ExternalId for cross-account trust
  // Non-secret pointer to the HashiCorp Vault path holding this provider's AWS
  // access key + secret (KV v2). The secrets never touch Postgres — the runner
  // reads them from Vault at execution time. Null = no long-lived keys stored.
  credVaultPath String?
  region     String
  // Azure active context (the agent remembers the user's picks per project):
  resourceGroup    String? // active Azure resource group
  cloudEnvironment String  @default("AzurePublic") // AzurePublic | AzureUSGovernment | AzureChina
  status     HealthStatus @default(ok)
  createdAt  DateTime     @default(now())

  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  project        Project?             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  // `envs` and `services`/`spend` (counts/sums) derive from these relations:
  environments   Env[]
  resources      ManagedResource[]
  securityScopes CloudSecurityScope[]

  @@index([userId])
  @@index([projectId])
}

// Per-PROJECT HashiCorp Vault connection (isolation). Each project has its own
// Vault URL + token; the token is stored ENCRYPTED. AWS access keys are written
// into this Vault (KV v2). The agent resolves the connection at runtime from the
// provider's project. Falls back to VAULT_ADDR / VAULT_TOKEN env vars when no
// row exists.
model VaultConfig {
  id         String   @id @default(uuid(7)) @db.Uuid
  projectId  String   @unique @db.Uuid
  addr       String // Vault base URL, e.g. https://vault.example.com:8200
  tokenEnc   String // AES-encrypted Vault token (hvs.…) — never plaintext at rest
  kvMount    String   @default("secret") // KV v2 mount point
  pathPrefix String   @default("dda/cloud") // namespace for stored secrets
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ⚠ confirm — "attach envs from security service for cloud": modelled as
// cloud-side security constructs (security groups, IAM roles, KMS keys, secret
// stores, network policies) that get bound to one or more environments.
model CloudSecurityScope {
  id              String            @id @default(uuid(7)) @db.Uuid
  cloudProviderId String            @db.Uuid
  kind            SecurityScopeKind
  name            String
  ref             String? // ARN / resource id
  metadata        Json?
  createdAt       DateTime          @default(now())

  cloudProvider CloudProvider        @relation(fields: [cloudProviderId], references: [id], onDelete: Cascade)
  bindings      EnvSecurityBinding[]

  @@index([cloudProviderId])
}

model EnvSecurityBinding {
  id        String   @id @default(uuid(7)) @db.Uuid
  envId     String   @db.Uuid
  scopeId   String   @db.Uuid
  createdAt DateTime @default(now())

  env   Env                @relation(fields: [envId], references: [id], onDelete: Cascade)
  scope CloudSecurityScope @relation(fields: [scopeId], references: [id], onDelete: Cascade)

  @@unique([envId, scopeId])
}

// ---------------------------------------------------------------------------
// Integrations (per-project) — two connectivity types: OAuth vs credential
// ---------------------------------------------------------------------------
// The settings "Connected services" panel mixes two connection flows:
//   • oauth      — GitHub / Slack / Grafana: authorize redirect, store tokens.
//   • credential — cloud (Role ARN), API-key / webhook services: enter secrets.
// `action` and `connected:boolean` from the mock are DROPPED — the UI derives
// the button label ("Connect" / "Manage" / "Configure") from authType + status.
// Note: cloud providers are also first-class CloudProvider rows; this Integration
// row is the connector card shown in settings. // ⚠ confirm scope (see chat).

enum IntegrationAuthType {
  oauth
  credential
}

enum IntegrationStatus {
  disconnected
  connected
  error
  expired // OAuth token lapsed / credential rejected
}

model Integration {
  id            String              @id @default(uuid(7)) @db.Uuid
  projectId     String              @db.Uuid
  provider      String // "github" | "cloud" | "grafana" | "slack" | …
  name          String
  icon          String
  description   String
  authType      IntegrationAuthType
  status        IntegrationStatus   @default(disconnected)
  connectedById String?             @db.Uuid // user who established the connection
  connectedAt   DateTime?
  lastSyncedAt  DateTime?
  createdAt     DateTime            @default(now())

  project     Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  connectedBy User?                   @relation(fields: [connectedById], references: [id])
  oauth       IntegrationOAuth? // present when authType = oauth
  credentials IntegrationCredential[] // present when authType = credential

  @@unique([projectId, provider])
}

// OAuth connection detail — tokens stored as encrypted refs, never plaintext.
model IntegrationOAuth {
  id                   String    @id @default(uuid(7)) @db.Uuid
  integrationId        String    @unique @db.Uuid
  externalAccountId    String? // e.g. GitHub org/user id
  externalAccountLabel String? // "org northwind-io"
  accessTokenRef       String // ciphertext or secret-manager handle
  refreshTokenRef      String?
  scopes               String[]
  expiresAt            DateTime?

  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
}

// Credential connection detail — one row per config key (role_arn, region,
// api_key, webhook_url, …). Values are encrypted refs, never plaintext.
model IntegrationCredential {
  id            String  @id @default(uuid(7)) @db.Uuid
  integrationId String  @db.Uuid
  key           String // "role_arn" | "region" | "api_key" | "webhook_url"
  valueRef      String // ciphertext or secret-manager handle (null label-only if non-secret)
  isSecret      Boolean @default(true)

  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([integrationId, key])
}

// ---------------------------------------------------------------------------
// Cost (structured — replaces the Cost Json blob)
// ---------------------------------------------------------------------------
model CostSnapshot {
  id            String   @id @default(uuid(7)) @db.Uuid
  projectId     String   @db.Uuid
  periodStart   DateTime // first day of the month this snapshot covers
  totalCents    Int
  forecastCents Int?
  budgetCents   Int?
  savingsCents  Int?
  untaggedCents Int?
  createdAt     DateTime @default(now())

  project   Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  byEnv     CostByEnv[]
  byService CostByService[]

  @@unique([projectId, periodStart])
}

model CostByEnv {
  id          String   @id @default(uuid(7)) @db.Uuid
  snapshotId  String   @db.Uuid
  envId       String?  @db.Uuid
  label       String // "Release", "Shared" (Shared has no Env)
  amountCents Int
  createdAt   DateTime @default(now())

  snapshot CostSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  env      Env?         @relation(fields: [envId], references: [id])

  @@index([snapshotId])
}

model CostByService {
  id          String   @id @default(uuid(7)) @db.Uuid
  snapshotId  String   @db.Uuid
  service     String // "EKS · compute"
  amountCents Int
  pct         Int?
  createdAt   DateTime @default(now())

  snapshot CostSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([snapshotId])
}

// 12-month trend series for the cost chart.
model CostTrendPoint {
  id          String   @id @default(uuid(7)) @db.Uuid
  projectId   String   @db.Uuid
  monthStart  DateTime
  amountCents Int

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, monthStart])
}

// ---------------------------------------------------------------------------
// Observability (ProjStats tab) — persisted KPIs + monitoring links
// ---------------------------------------------------------------------------
model ObservabilityKpi {
  id         String       @id @default(uuid(7)) @db.Uuid
  projectId  String       @db.Uuid
  envId      String?      @db.Uuid
  name       String // "API latency p95"
  value      String // display value ("84 ms")
  unit       String?
  tone       HealthStatus @default(ok)
  series     Int[] // sparkline points
  capturedAt DateTime     @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

enum TargetStatus {
  up
  down
}

model PrometheusTarget {
  id        String       @id @default(uuid(7)) @db.Uuid
  projectId String       @db.Uuid
  name      String
  status    TargetStatus
  series    Int? // active series count
  createdAt DateTime     @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model GrafanaDashboard {
  id        String   @id @default(uuid(7)) @db.Uuid
  projectId String   @db.Uuid
  title     String
  url       String?
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// ---------------------------------------------------------------------------
// Platform: agents + models + MCP (admin-configured, used across projects)
// ---------------------------------------------------------------------------
// Admin-managed platform agents (not user-owned), referenced across projects.
model Agent {
  id                 String   @id @default(uuid(7)) @db.Uuid
  name               String
  skill              String
  triggerDescription String // "On issue + PR", "Daily", …
  approvalPolicy     String // "Auto-close low risk", "Human for prod", …
  modelId            String?  @db.Uuid
  enabled            Boolean  @default(true)
  systemPrompt       String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  model        Model?        @relation(fields: [modelId], references: [id])
  approvals    Approval[]
  activities   Activity[]
  alerts       Alert[]
  tasks        Task[]
  pipelines    Pipeline[]
  issues       Issue[]
  deployments  Deployment[]
  chatMessages ChatMessage[]
}

model Model {
  id                     String        @id @default(uuid(7)) @db.Uuid
  name                   String
  provider               ModelProvider
  ctxTokens              Int? // 200_000, 1_000_000 (parsed from "200k"/"1M")
  inputCostPerMTokCents  Int? // parsed from "$3 / $15 per Mtok"
  outputCostPerMTokCents Int?
  costNote               String? // "GPU node", or free-form when not per-token
  // Admin-managed catalog. `isDefault` is the platform default model used by
  // every user across all projects; ProjectSetting.defaultModelId can override
  // it per project. Models are not user-owned.
  isDefault              Boolean       @default(false)
  enabled                Boolean       @default(true)

  agents         Agent[]
  projectDefault ProjectSetting[]
  chatMessages   ChatMessage[]
}

model McpConnector {
  id             String      @id @default(uuid(7)) @db.Uuid
  name           String
  description    String
  status         McpStatus   @default(ok)
  authType       McpAuthType @default(none)
  avgCallsPerDay Int? // parsed from "84.2k / day"
  avgLatencyMs   Int? // parsed from "120ms"
  createdAt      DateTime    @default(now())

  oauth              McpOAuth?
  credentials        McpCredential[]
  projectConnections ProjectMcpConnection[]
}

// Platform-level OAuth for an MCP server (admin-authorized). For per-project
// authorization, attach tokens to ProjectMcpConnection instead.
model McpOAuth {
  id                  String    @id @default(uuid(7)) @db.Uuid
  connectorId         String    @unique @db.Uuid
  accessTokenRef      String // encrypted ref, never plaintext
  refreshTokenRef     String?
  scopes              String[]
  tokenType           String? // "Bearer"
  authorizationServer String? // OAuth issuer / discovery URL
  expiresAt           DateTime?

  connector McpConnector @relation(fields: [connectorId], references: [id], onDelete: Cascade)
}

model McpCredential {
  id          String  @id @default(uuid(7)) @db.Uuid
  connectorId String  @db.Uuid
  key         String // "api_key" | "pat" | "aws_role_arn" | …
  valueRef    String // encrypted ref, never plaintext
  isSecret    Boolean @default(true)

  connector McpConnector @relation(fields: [connectorId], references: [id], onDelete: Cascade)

  @@unique([connectorId, key])
}

// The missing Project <-> MCP link: a project's connection to an MCP server.
// Per-project authorization (when used) lives here.
model ProjectMcpConnection {
  id            String            @id @default(uuid(7)) @db.Uuid
  projectId     String            @db.Uuid
  connectorId   String            @db.Uuid
  enabled       Boolean           @default(true)
  status        IntegrationStatus @default(disconnected)
  connectedById String?           @db.Uuid // user id (soft ref) who established the connection
  connectedAt   DateTime?
  createdAt     DateTime          @default(now())

  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  connector McpConnector @relation(fields: [connectorId], references: [id])

  @@unique([projectId, connectorId])
}

// ---------------------------------------------------------------------------
// Platform settings (admin) — small singleton-ish config tables
// ---------------------------------------------------------------------------
model PlatformSetting {
  id              String    @id @default(uuid(7)) @db.Uuid
  siteTitle       String
  metaDescription String
  smtpHost        String?
  smtpPort        Int?
  fromAddress     String?
  smtpVerifiedAt  DateTime? // when SMTP was last verified (NOT a user's email)
  updatedAt       DateTime  @updatedAt
}

model PlatformAsset {
  id        String   @id @default(uuid(7)) @db.Uuid
  key       String   @unique // "logo" | "favicon" | "og"
  label     String
  hint      String
  url       String?
  updatedAt DateTime @updatedAt
}

// Secret config — store an encrypted reference/handle, NEVER the plaintext value.
model PlatformEnvVar {
  id          String       @id @default(uuid(7)) @db.Uuid
  key         String       @unique
  valueRef    String // encrypted ciphertext or secret-manager handle
  status      HealthStatus @default(ok)
  statusLabel String // "Set" | "Expiring" | …
  updatedAt   DateTime     @updatedAt
}

// OAuth client credentials managed from the admin UI rather than env vars,
// so an operator can rotate keys without redeploying. clientSecretRef holds
// the AES-GCM ciphertext of the client secret; clientId is stored plaintext
// (it's already shipped to the browser as part of the authorize URL).
model OAuthProviderConfig {
  id              String        @id @default(uuid(7)) @db.Uuid
  provider        OAuthProvider @unique
  clientId        String // public — appears in the authorize URL
  clientSecretRef String // AES-GCM ciphertext via encryptSecret()
  enabled         Boolean       @default(true)
  updatedAt       DateTime      @updatedAt
}

// ⚠ confirm — system health is really live/runtime; persisted here only so the
// admin status board has something to render. Could be replaced by live checks.
model SystemComponent {
  id     String       @id @default(uuid(7)) @db.Uuid
  key    String       @unique
  name   String
  status HealthStatus @default(ok)
  note   String
}

// ---------------------------------------------------------------------------
// Security audit log — immutable, append-only trail of sensitive events
// ---------------------------------------------------------------------------
// Distinct from the per-project Activity feed (display-oriented). Records
// account/billing/auth-sensitive events: logins, MFA enroll/disable, backup-code
// regen, session revoke, password/email changes, plan/payment changes, role
// changes, invite accept/revoke, deploy/rollback approvals.
model AuditLog {
  id         String   @id @default(uuid(7)) @db.Uuid
  userId     String?  @db.Uuid // actor (null = system)
  projectId  String?  @db.Uuid // scope, when project-related
  action     String // "user.login", "mfa.disabled", "deploy.rollback", "billing.plan_changed"
  targetType String?
  targetId   String?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  user    User?    @relation(fields: [userId], references: [id])
  project Project? @relation(fields: [projectId], references: [id])

  @@index([userId, createdAt])
  @@index([projectId, createdAt])
}

